local function updateESPforPlayer(player)
    local espData = espObjects[player]
    if not espData or not player.Character then return end
    
    -- Подсветка игрока
    if espEnabled then
        if not espData.highlight then
            local highlight = Instance.new("Highlight")
            highlight.Name = "Highlight_" .. player.Name
            highlight.FillColor = espColor
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = espColor
            highlight.OutlineTransparency = 0.3
            highlight.Adornee = player.Character
            highlight.Parent = player.Character
            espData.highlight = highlight
        else
            espData.highlight.Adornee = player.Character
            espData.highlight.FillColor = espColor
            espData.highlight.OutlineColor = espColor
            espData.highlight.Visible = true
        end
    elseif espData.highlight then
        espData.highlight:Destroy()
        espData.highlight = nil
    end
    
    -- Billboard для имени и ХП
    if espData.billboard then
        if not espData.nameText then
            local nameText = Instance.new("TextLabel")
            nameText.Size = UDim2.new(1, 0, 0.5, 0)
            nameText.Position = UDim2.new(0, 0, 0, 0)
            nameText.BackgroundTransparency = 1
            nameText.Text = player.Name
            nameText.TextColor3 = Color3.fromRGB(255, 255, 255)
            nameText.TextSize = 12
            nameText.Font = Enum.Font.GothamBold
            nameText.Parent = espData.billboard
            espData.nameText = nameText
        end
        
        if not espData.healthText then
            local healthText = Instance.new("TextLabel")
            healthText.Size = UDim2.new(1, 0, 0.4, 0)
            healthText.Position = UDim2.new(0, 0, 0.5, 0)
            healthText.BackgroundTransparency = 1
            healthText.TextColor3 = Color3.fromRGB(255, 255, 255)
            healthText.TextStrokeTransparency = 0.3
            healthText.TextSize = 11
            healthText.Font = Enum.Font.GothamBold
            healthText.Text = "100 HP"
            healthText.Parent = espData.billboard
            espData.healthText = healthText
        end
    end
end

local function createESP(player)
    if espObjects[player] then return end
    
    local espData = {}
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_" .. player.Name
    billboard.Size = UDim2.new(0, 100, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = player.Character and player.Character:FindFirstChild("Head")
    espData.billboard = billboard
    
    espObjects[player] = espData
    updateESPforPlayer(player)
    
    local function updateHealthAndPosition()
        if not player.Character or not player.Character:FindFirstChild("Head") then return end
        
        if billboard then
            billboard.Parent = player.Character.Head
        end
        
        if espData.highlight and espEnabled then
            espData.highlight.Adornee = player.Character
        end
        
        if player.Character:FindFirstChild("Humanoid") and espData.healthText then
            local hum = player.Character.Humanoid
            local health = hum.Health
            local maxHealth = hum.MaxHealth
            local percent = health / maxHealth
            espData.healthText.Text = math.floor(health) .. "/" .. math.floor(maxHealth) .. " HP"
            if percent > 0.6 then
                espData.healthText.TextColor3 = Color3.fromRGB(0, 255, 0)
            elseif percent > 0.3 then
                espData.healthText.TextColor3 = Color3.fromRGB(255, 255, 0)
            else
                espData.healthText.TextColor3 = Color3.fromRGB(255, 0, 0)
            end
        end
    end
    
    updateHealthAndPosition()
    
    local conn = RS.Heartbeat:Connect(updateHealthAndPosition)
    espData.updateConnection = conn
end

local function removeESP(player)
    local data = espObjects[player]
    if data then
        if data.highlight then data.highlight:Destroy() end
        if data.billboard then data.billboard:Destroy() end
        if data.healthText then data.healthText:Destroy() end
        if data.nameText then data.nameText:Destroy() end
        if data.updateConnection then data.updateConnection:Disconnect() end
        espObjects[player] = nil
    end
end

local function refreshESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            if espEnabled and p.Character then
                if not espObjects[p] then
                    createESP(p)
                else
                    updateESPforPlayer(p)
                end
            elseif not espEnabled and espObjects[p] then
                removeESP(p)
            end
        end
    end
end

local function toggleESP()
    espEnabled = not espEnabled
    if espEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                createESP(p)
            end
        end
        Players.PlayerAdded:Connect(function(p)
            if espEnabled and p ~= LP then
                p.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if espEnabled and p ~= LP and p.Character then
                        createESP(p)
                    end
                end)
            end
        end)
        Players.PlayerRemoving:Connect(function(p) removeESP(p) end)
    else
        for p,_ in pairs(espObjects) do
            removeESP(p)
        end
    end
end

