UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode.Name == teleportKey and teleportEnabled then
        local mousePos = Mouse.Hit.Position
        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            LP.Character.HumanoidRootPart.CFrame = CFrame.new(mousePos.X, mousePos.Y + 3, mousePos.Z)
        end
    end
    if input.KeyCode.Name == aimKey then
        if aimMode == "Hold" then
            if not aimHoldActive then
                aimHoldActive = true
                aimEnabled = true
                aimCircle.Visible = true
                aimGlow.Visible = true
                currentCamCFrame = Camera.CFrame
                startAim()
                if aimCycle then aimCycleTimer = 0; aimCycleCurrent = aimTarget; startCycle() end
                btn2.Text = "Аим (наводка на человека) [ВКЛ]"
                btn2.TextColor3 = Color3.fromRGB(100,255,100)
            end
        elseif aimMode == "Toggle" then
            toggleAim()
            if aimEnabled then
                if aimCycle then aimCycleTimer = 0; aimCycleCurrent = aimTarget; startCycle() end
                btn2.Text = "Аим (наводка на человека) [ВКЛ]"
                btn2.TextColor3 = Color3.fromRGB(100,255,100)
            else
                btn2.Text = "Аим (наводка на человека)"
                btn2.TextColor3 = Color3.fromRGB(200,200,220)
            end
        end
    end
    if input.KeyCode.Name == espKey then
        toggleESP()
        if espEnabled then
            btn3.Text = "ESP (подсветка, имя, ХП) [ВКЛ]"
            btn3.TextColor3 = Color3.fromRGB(100,255,100)
        else
            btn3.Text = "ESP (подсветка, имя, ХП)"
            btn3.TextColor3 = Color3.fromRGB(200,200,220)
        end
    end
    if input.KeyCode.Name == flyKey then
        toggleFly()
        local flyBtnEnable = flyContent:FindFirstChildWhichIsA("TextButton")
        if flyBtnEnable and flyBtnEnable.Name == "enableBtn" then
            flyBtnEnable.Text = flyEnabled and "Полёт: ВКЛ" or "Полёт: ВЫКЛ"
            flyBtnEnable.BackgroundColor3 = flyEnabled and Color3.fromRGB(80,120,255) or Color3.fromRGB(45,45,60)
        end
    end
    if input.KeyCode.Name == menuKey then
        if menuVisible then HideMenuWithAnimation() else ShowMenuWithAnimation() end
    end
end)

UIS.InputEnded:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode.Name == aimKey and aimMode == "Hold" then
        if aimHoldActive then
            aimHoldActive = false
            aimEnabled = false
            aimCircle.Visible = false
            aimGlow.Visible = false
            if aimConnection then aimConnection:Disconnect(); aimConnection = nil end
            btn2.Text = "Аим (наводка на человека)"
            btn2.TextColor3 = Color3.fromRGB(200,200,220)
        end
    end
end)

-- ==================== ПЕРЕТАСКИВАНИЕ ОКНА ====================
local dragging = false
local dragStart, frameStart

topPanel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        frameStart = mainFrame.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

