-- Создание кнопок в левой панели
local function createFunctionButton(name, icon, contentFrame)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 50)
    btn.Position = UDim2.new(0, 5, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
    btn.BackgroundTransparency = 0.5
    btn.BorderSizePixel = 0
    btn.Text = icon .. " " .. name
    btn.TextColor3 = Color3.fromRGB(220, 220, 240)
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamSemibold
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.TextYAlignment = Enum.TextYAlignment.Center
    btn.Parent = leftPanel
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = btn
    
    local function updateSize(expanded)
        local targetSize = expanded and UDim2.new(1, -10, 0, 70) or UDim2.new(1, -10, 0, 50)
        local targetTextSize = expanded and 16 or 14
        local tween = TS:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = targetSize})
        tween:Play()
        btn.TextSize = targetTextSize
    end
    
    btn.MouseEnter:Connect(function()
        if selectedFunction ~= btn then
            updateSize(true)
            for _, other in pairs(functionButtons) do
                if other ~= btn and other.Size.Y.Offset == 70 then
                    TS:Create(other, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, -10, 0, 50)}):Play()
                    other.TextSize = 14
                end
            end
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if selectedFunction ~= btn then
            updateSize(false)
        end
    end)
    
    btn.MouseButton1Click:Connect(function()
        if selectedFunction == btn then return end
        
        if selectedFunction then
            TS:Create(selectedFunction, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, -10, 0, 50)}):Play()
            selectedFunction.TextSize = 14
        end
        
        selectedFunction = btn
        updateSize(true)
        
        for _, child in pairs(contentContainer:GetChildren()) do
            if child:IsA("ScrollingFrame") then
                child.Visible = false
            end
        end
        contentFrame.Visible = true
    end)
    
    table.insert(functionButtons, btn)
    return btn
end

