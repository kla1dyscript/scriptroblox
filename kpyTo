local aimHoldActive = false

local function ShowMenuWithAnimation()
    if isAnim or menuVisible then return end
    isAnim = true
    menuVisible = true
    mainFrame.Visible = true
    mainFrame.Size = UDim2.new(0,0,0,0)
    mainFrame.Position = UDim2.new(0.5,0,0.5,0)
    local tweenSize = TS:Create(mainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0,900,0,700)})
    local tweenPos = TS:Create(mainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0.5,-450,0.5,-350)})
    tweenSize:Play()
    tweenPos:Play()
    tweenPos.Completed:Connect(function() isAnim = false end)
end

local function HideMenuWithAnimation()
    if isAnim or not menuVisible then return end
    isAnim = true
    menuVisible = false
    local tweenSize = TS:Create(mainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0,0,0,0)})
    local tweenPos = TS:Create(mainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(0.5,0,0.5,0)})
    tweenSize:Play()
    tweenPos:Play()
    tweenPos.Completed:Connect(function()
        mainFrame.Visible = false
        isAnim = false
    end)
end

