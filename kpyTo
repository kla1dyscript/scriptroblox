-- ==================== АИМ ====================
local aimConnection = nil
local aimTargetPart = nil
local aimTargetPlayer = nil

local function findBestTarget()
    local target = aimTarget
    if aimCycle then target = aimCycleCurrent end
    
    local bestPlayer = nil
    local bestPart = nil
    local bestDistance = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local fovSquared = aimFOV * aimFOV
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild(target) and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local part = p.Character:FindFirstChild(target)
            if part then
                local screenPoint, onScreen = Camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dx = screenPoint.X - screenCenter.X
                    local dy = screenPoint.Y - screenCenter.Y
                    local distSquared = dx*dx + dy*dy
                    if distSquared <= fovSquared and distSquared < bestDistance then
                        bestDistance = distSquared
                        bestPlayer = p
                        bestPart = part
                    end
                end
            end
        end
    end
    
    aimTargetPlayer = bestPlayer
    aimTargetPart = bestPart
    return bestPart, bestPlayer
end

local function updateAim()
    if not aimEnabled then return end
    
    local targetPart = findBestTarget()
    if targetPart then
        local targetPos = targetPart.Position
        local cameraPos = Camera.CFrame.Position
        local targetCF = CFrame.new(cameraPos, targetPos)
        
        if aimSmooth > 0 then
            currentCamCFrame = currentCamCFrame:Lerp(targetCF, aimSmooth)
            Camera.CFrame = currentCamCFrame
        else
            Camera.CFrame = targetCF
            currentCamCFrame = targetCF
        end
    end
end

local function startAim()
    if aimConnection then aimConnection:Disconnect() end
    aimConnection = RS.RenderStepped:Connect(updateAim)
end

local function toggleAim()
    aimEnabled = not aimEnabled
    aimCircle.Visible = aimEnabled
    aimGlow.Visible = aimEnabled
    if aimEnabled then
        currentCamCFrame = Camera.CFrame
        startAim()
        if aimCycle then aimCycleTimer = 0; aimCycleCurrent = aimTarget; startCycle() end
    else
        if aimConnection then aimConnection:Disconnect(); aimConnection = nil end
        aimTargetPart = nil
        aimTargetPlayer = nil
    end
end

local cycleConnection
local function startCycle()
    if cycleConnection then cycleConnection:Disconnect() end
    cycleConnection = RS.Heartbeat:Connect(function(dt)
        if aimEnabled and aimCycle then
            aimCycleTimer = aimCycleTimer + dt
            if aimCycleCurrent == "Head" and aimCycleTimer >= aimCycleHead then
                aimCycleCurrent = "HumanoidRootPart"; aimCycleTimer = 0
            elseif aimCycleCurrent == "HumanoidRootPart" and aimCycleTimer >= aimCycleBody then
                aimCycleCurrent = "Head"; aimCycleTimer = 0
            end
        end
    end)
end

local function toggleCycle()
    aimCycle = not aimCycle
    if aimCycle then aimCycleTimer = 0; aimCycleCurrent = aimTarget; startCycle() end
end

-- ==================== HITBOX ====================
local function applyHitbox(player)
    if not hitboxEnabled then return end
    local char = player.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    local torso = char:FindFirstChild("HumanoidRootPart")
    if head and not head:FindFirstChild("HitboxExpander") then
        local hs = Instance.new("NumberValue")
        hs.Name = "HitboxExpander"
        hs.Value = hitboxHead
        hs.Parent = head
        local conn = head:GetPropertyChangedSignal("Size"):Connect(function()
            if hitboxEnabled and head:FindFirstChild("HitboxExpander") then
                head.Size = Vector3.new(2,2,2) * head.HitboxExpander.Value
            end
        end)
        head.Size = Vector3.new(2,2,2) * hitboxHead
        if not hitboxConns[player] then hitboxConns[player] = {} end
        hitboxConns[player].head = conn
    end
    if torso and not torso:FindFirstChild("HitboxExpander") then
        local ts = Instance.new("NumberValue")
        ts.Name = "HitboxExpander"
        ts.Value = hitboxBody
        ts.Parent = torso
        local conn = torso:GetPropertyChangedSignal("Size"):Connect(function()
            if hitboxEnabled and torso:FindFirstChild("HitboxExpander") then
                torso.Size = Vector3.new(2,3,1) * torso.HitboxExpander.Value
            end
        end)
        torso.Size = Vector3.new(2,3,1) * hitboxBody
        if not hitboxConns[player] then hitboxConns[player] = {} end
        hitboxConns[player].torso = conn
    end
end

local function removeHitbox(player)
    local char = player.Character
    if char then
        local head = char:FindFirstChild("Head")
        local torso = char:FindFirstChild("HumanoidRootPart")
        if head then
            local val = head:FindFirstChild("HitboxExpander")
            if val then val:Destroy() end
            head.Size = Vector3.new(2,2,2)
        end
        if torso then
            local val = torso:FindFirstChild("HitboxExpander")
            if val then val:Destroy() end
            torso.Size = Vector3.new(2,3,1)
        end
    end
    if hitboxConns[player] then
        if hitboxConns[player].head then hitboxConns[player].head:Disconnect() end
        if hitboxConns[player].torso then hitboxConns[player].torso:Disconnect() end
        hitboxConns[player] = nil
    end
end

local function toggleHitbox()
    hitboxEnabled = not hitboxEnabled
    if hitboxEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP then applyHitbox(p) end
        end
        Players.PlayerAdded:Connect(function(p)
            if hitboxEnabled and p ~= LP then
                p.CharacterAdded:Connect(function() task.wait(0.5); if hitboxEnabled and p ~= LP then applyHitbox(p) end end)
            end
        end)
        Players.PlayerRemoving:Connect(function(p) removeHitbox(p) end)
    else
        for _, p in ipairs(Players:GetPlayers()) do if p ~= LP then removeHitbox(p) end end
    end
end

local function updateHitboxSizes()
    if not hitboxEnabled then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            local char = p.Character
            if char then
                local head = char:FindFirstChild("Head")
                local torso = char:FindFirstChild("HumanoidRootPart")
                if head and head:FindFirstChild("HitboxExpander") then
                    head.HitboxExpander.Value = hitboxHead
                    head.Size = Vector3.new(2,2,2) * hitboxHead
                end
                if torso and torso:FindFirstChild("HitboxExpander") then
                    torso.HitboxExpander.Value = hitboxBody
                    torso.Size = Vector3.new(2,3,1) * hitboxBody
                end
            end
        end
    end
end

-- ==================== ПОЛЁТ ====================
local function startFly()
    local char = LP.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then humanoid.PlatformStand = true end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    flyVel = Instance.new("BodyVelocity")
    flyVel.MaxForce = Vector3.new(1,1,1) * 100000
    flyVel.Parent = rootPart
    flyGyro = Instance.new("BodyGyro")
    flyGyro.MaxTorque = Vector3.new(1,1,1) * 100000
    flyGyro.Parent = rootPart
    flyConn = RS.RenderStepped:Connect(function()
        if not flyEnabled or not char or not char.Parent then return end
        local moveDir = Vector3.new(
            (UIS:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UIS:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
            (UIS:IsKeyDown(Enum.KeyCode.Space) and 1 or 0) - (UIS:IsKeyDown(Enum.KeyCode.LeftControl) and 1 or 0),
            (UIS:IsKeyDown(Enum.KeyCode.S) and 1 or 0) - (UIS:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
        )
        local camCF = Camera.CFrame
        local moveVelCalc = camCF:VectorToWorldSpace(moveDir) * flySpeed
        if flyVel then flyVel.Velocity = moveVelCalc end
        if flyGyro then flyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + camCF.LookVector) end
    end)
end

local function stopFly()
    if flyConn then flyConn:Disconnect() end
    local char = LP.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then humanoid.PlatformStand = false end
        if flyVel then flyVel:Destroy() end
        if flyGyro then flyGyro:Destroy() end
    end
    flyConn = nil
    flyVel = nil
    flyGyro = nil
end

local function toggleFly()
    flyEnabled = not flyEnabled
    if flyEnabled then startFly() else stopFly() end
end

